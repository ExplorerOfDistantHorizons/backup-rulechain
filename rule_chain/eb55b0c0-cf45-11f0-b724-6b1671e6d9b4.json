      },
      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "function nextRelation(metadata, msg) {\n    var out_list = [];\n    switch (msg.method) {\n        case \"control\":\n        case \"controlRelay\":\n            out_list = ['control']\n            break;\n\n        case \"switchMode\":\n            out_list = ['switchMode']\n            break;\n            \n        case \"ping\":    \n        case \"pingGw\":\n            out_list = ['pingGw']\n            break;\n    \n        case \"configNetworkGw\":\n            out_list = ['configNetworkGw']\n            break;\n            \n        case \"delGw\":\n            out_list = ['delGw']\n            break;\n\n        case \"restart\":\n            out_list = ['restart']\n            break;\n    \n        case \"commander\":\n            out_list = ['commander']\n            break;\n        \n        case \"createGroup\":\n        case \"addDevToGroup\":\n        case \"delDevFromGroup\":\n        case \"delGroup\":\n        case \"createNormalGroup\":\n            out_list = ['groupManager']\n            break;\n        \n        \n        case \"setScene\":\n        case \"deleteScene\": \n        case \"activeScene\": \n        case \"stopScene\":\n        \n        case \"setSceneGw\":\n        case \"delSceneGw\": \n        case \"enableSceneGw\": \n        case \"disableSceneGw\":\n            out_list = ['ruleManager']\n            break;        \n        \n        case \"registerDev\":\n        case \"delDev\":\n        case \"locationDev\":\n        case \"attributesDev\":\n        case \"configDev\": \n        case \"configNetworkDev\": \n        case \"pingDev\":\n        case \"controlDev\":\n        case \"modeActionDev\":\n        case \"setSceneDev\":\n        case \"delDevFromScene\":\n        case \"delSceneDev\":\n        case \"enableSceneDev\":\n        case \"disableSceneDev\":\n            out_list = ['deviceManager']\n            break;\n        \n        default:\n            out_list = ['otherMethod']\n            break;\n    }\n    return out_list;\n}\nreturn nextRelation(metadata, msg);",
        "tbelScript" : "function nextRelation(metadata, msg) {\n    return ['one','nine'];\n}\nif(msgType == 'POST_TELEMETRY_REQUEST') {\n    return ['two'];\n}\nreturn nextRelation(metadata, msg);"
      },
      "configurationVersion" : 0,
      "createdTime" : 0,
      "debugMode" : true,
      "externalId" : null,
