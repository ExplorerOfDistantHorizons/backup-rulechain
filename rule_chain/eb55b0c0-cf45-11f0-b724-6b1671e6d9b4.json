      },
      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "var dayNames = [\"Sun\", \"Mon\", \"Tue\", \"Wed\", \"Thu\", \"Fri\", \"Sat\"];\r\n\r\n// Lấy thời gian hiện tại theo giờ VN\r\nvar now = new Date(Date.now() + 7 * 60 * 60 * 1000);\r\n\r\n// Lấy thứ trong tuần\r\nvar weekday = dayNames[now.getDay()];\r\n\r\nmsg = {\r\n    \"method\": \"getTimeCloudRsp\",\r\n    \"rqi\": msg.rqi,\r\n    \"params\": {\r\n        \"code\": 0,\r\n        \"time\": now,\r\n        \"weekday\": weekday\r\n    }\r\n};\r\n\r\nreturn {\r\n    msg: msg,\r\n    metadata: metadata,\r\n    msgType: msgType\r\n};\r\n",
        "tbelScript" : "var cmd = msg.method;\nvar response;\n\nif(cmd === \"deviceUpdate\"){\n    response = {\n        \"method\": \"deviceUpdateRsp\",\n        \"rqi\": msg.rqi,\n        \"params\": {\n            \"code\": 0\n        }\n    }\n    return {msg: response, metadata: metadata, msgType: msgType};\n}\nelse if(cmd ===\"newDev\"){\n    response = {\n        \"method\": \"newDevRsp\",\n        \"rqi\": msg.rqi,\n        \"params\": {\n            \"code\": 0\n        }\n    }\n    return {msg: response, metadata: metadata, msgType: msgType};\n}\nelse if(cmd ===\"deviceControlFailure\"){\n    response = {\n        \"method\": \"deviceControlFailureRsp\",\n        \"rqi\": msg.rqi,\n        \"params\": {\n            \"code\": 0\n        }\n    }\n    return {msg: response, metadata: metadata, msgType: msgType};\n}\nreturn {msg: msg, metadata: metadata, msgType: msgType};"
      },
      "configurationVersion" : 0,
      "createdTime" : 0,
      "debugMode" : false,
      "externalId" : null,
      "id" : {
