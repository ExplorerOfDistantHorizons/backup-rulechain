      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "var gatewayTypes = [\"GATEWAY_HC02\"]\nvar deviceDirectType = [\"CTCU_WIFI_4\", \"CTCU_WIFI_3\",\"CTCU_WIFI_2\", \"CTCU_WIFI_1\"]\nvar dataControl = JSON.parse(metadata.nextData)\n\nif (gatewayTypes.indexOf(msg.profileName) != -1) {\n    metadata.profileName = \"GATEWAY\"\n    msg = {\n        \"method\": \"controlAllDev\",\n        \"params\": dataControl.params\n    };\n} else {\n    if (deviceDirectType.indexOf(msg.profileName) != -1) {\n        metadata.profileName = \"DEVICE_DIRECT\"\n        msg = {\n            \"method\": \"controlDev\",\n            \"params\": {\n                bt: dataControl.params.bt,\n                dim: dataControl.params.dim\n\n            }\n        };\n\n\n    } else {\n        metadata.profileName = msg.profileName\n    }\n}\n\n\n\nmetadata.expirationTime = Date.now() + 10000;\nmetadata.originServiceId = metadata.serviceId;\nmetadata.oneway = false;\nmsgType = \"RPC_CALL_FROM_SERVER_TO_DEVICE\"\n\nreturn {\n    msg: msg,\n    metadata: metadata,\n    msgType: msgType\n};",
