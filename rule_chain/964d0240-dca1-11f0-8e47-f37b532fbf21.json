      },
      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "function nextRelation(metadata, msg) {\r\n    var out_list = [];\r\n    var values = msg.params;\r\n\r\n    var method = null;\r\n    var hasValidControlField = false;\r\n    var isInvalid = false;\r\n\r\n    for (var key in values) {\r\n        if (values.hasOwnProperty(key)) {\r\n            var val = values[key];\r\n\r\n            if (key === \"dim\" || key === \"onoff\") {\r\n\r\n                // check type number\r\n                if (typeof val !== \"number\") {\r\n                    isInvalid = true;\r\n                    break;\r\n                }\r\n\r\n                // check integer\r\n                if (val % 1 !== 0) {\r\n                    isInvalid = true;\r\n                    break;\r\n                }\r\n\r\n                // check range\r\n                if (key === \"dim\") {\r\n                    if (val < 0 || val > 100) {\r\n                        isInvalid = true;\r\n                        break;\r\n                    }\r\n                }\r\n\r\n                if (key === \"onoff\") {\r\n                    if (val < 0 || val > 1) {\r\n                        isInvalid = true;\r\n                        break;\r\n                    }\r\n                }\r\n\r\n                // field hợp lệ\r\n                hasValidControlField = true;\r\n            }\r\n        }\r\n    }\r\n\r\n    if (msg.method != null && hasValidControlField && !isInvalid){\r\n        method = \"controlEntity\";\r\n    }else{\r\n        method = msg.method\r\n    }\r\n\r\n    switch (method) {\r\n        case \"controlEntity\":\r\n            out_list = ['controlEntity'];\r\n            break;\r\n            \r\n        case \"createRoom\":\r\n            out_list = ['createRoom'];\r\n            break;\r\n            \r\n        default:\r\n            out_list = ['otherMethod'];\r\n            break;\r\n    }\r\n\r\n    return out_list;\r\n}\r\n\r\nreturn nextRelation(metadata, msg);",
        "tbelScript" : "function nextRelation(metadata, msg) {\n    return ['one','nine'];\n}\nif(msgType == 'POST_TELEMETRY_REQUEST') {\n    return ['two'];\n}\nreturn nextRelation(metadata, msg);"
      },
